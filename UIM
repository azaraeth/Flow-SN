prompt_line() {
  local status=""
  if [[ -d "$DATA/$PROJ" ]]; then
    if node_exists "start" 2>/dev/null; then
      status="${GR}●${RS}"
    else
      status="${OD}○${RS}"
    fi
  fi
  echo ""
  echo -ne "  ${status} ${OR}${BD}▶${RS} "
}

node_file()    { echo "$NODES/$1.node"; }
node_exists()  { [[ -f "$NODES/$1.node" ]]; }
node_type()    { sed -n '1p' "$NODES/$1.node" 2>/dev/null; }
node_subtype() { sed -n '2p' "$NODES/$1.node" 2>/dev/null; }
node_lang()    { sed -n '3p' "$NODES/$1.node" 2>/dev/null; }
node_body()    { tail -n +4 "$NODES/$1.node" 2>/dev/null; }

node_save() {
  local name="$1" type="$2" sub="$3" lang="$4"
  shift 4
  printf '%s\n%s\n%s\n%s\n' "$type" "$sub" "$lang" "$*" > "$NODES/$name.node"
}

node_list() { ls "$NODES"/*.node 2>/dev/null | xargs -I{} basename {} .node; }

node_delete() {
  rm -f "$NODES/$1.node"
  grep -v "^$1 \|^[^ ]* $1$" "$CONNS" > "$CONNS.tmp" 2>/dev/null
  mv "$CONNS.tmp" "$CONNS"
}

require_init() {
  node_exists "start" || { err "project not initialized — use: init $PROJ"; return 1; }
}

conn_add() {
  # $1=from  $2=to  $3=branch (optional: true|false)
  local branch="${3:-}"
  local entry="$1 $2${branch:+ $branch}"
  # prevent exact duplicate
  grep -qx "$entry" "$CONNS" 2>/dev/null && { warn "already linked: $1 → $2${branch:+ [$branch]}"; return 1; }
  echo "$entry" >> "$CONNS"
}

conn_remove() {
  # removes any connection from $1 to $2 regardless of branch tag
  grep -v "^$1 $2\( .*\)\?$" "$CONNS" > "$CONNS.tmp" 2>/dev/null
  mv "$CONNS.tmp" "$CONNS"
}

# conn_out <node>          — all children regardless of branch
# conn_out <node> true     — only true-branch children
# conn_out <node> false    — only false-branch children
conn_out() {
  local node="$1" branch="${2:-}"
  if [[ -z "$branch" ]]; then
    grep "^$node " "$CONNS" 2>/dev/null | awk '{print $2}'
  else
    grep "^$node " "$CONNS" 2>/dev/null | awk -v b="$branch" '$3==b{print $2}'
  fi
}

conn_in()  { grep " $1 \| $1$" "$CONNS" 2>/dev/null | awk '{print $1}'; }

# returns the branch tag for a specific connection (true/false/empty)
conn_branch() { grep "^$1 $2" "$CONNS" 2>/dev/null | awk '{print $3}'; }
