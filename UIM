# ── Colors ─────────────────────────────────────
OR='\033[38;5;208m'   # orange
OD='\033[38;5;166m'   # orange dim
GR='\033[38;5;114m'   # green
RE='\033[38;5;203m'   # red
BL='\033[38;5;111m'   # blue
GL='\033[38;5;245m'   # grey light
GY='\033[38;5;240m'   # grey
WH='\033[38;5;255m'   # white
WD='\033[38;5;250m'   # white dim
CY='\033[38;5;87m'    # cyan — decision nodes
MA='\033[38;5;129m'   # magenta — variable nodes
BD='\033[1m'
DM='\033[2m'
RS='\033[0m'

# ── Storage ─────────────────────────────────────
DATA="$HOME/.flowterm"
PROJ="project1"

use_proj() {
    PROJ="$1"
    NODES="$DATA/$PROJ/nodes"
    CONNS="$DATA/$PROJ/connections"
    mkdir -p "$NODES"
    touch "$CONNS"
}

# ── Node name validation ────────────────────────
# Only allow alphanumeric, underscore, and hyphen.
# Must not be empty, must not start with a hyphen,
# must not contain path separators or dots (no path traversal).
validate_node_name() {
  local name="$1"
  if [[ -z "$name" ]]; then
    err "node name cannot be empty"
    return 1
  fi
  if [[ "$name" =~ [^a-zA-Z0-9_-] ]]; then
    err "node name '$name' contains invalid characters — only a-z, A-Z, 0-9, _, - are allowed"
    return 1
  fi
  if [[ "$name" =~ ^- ]]; then
    err "node name '$name' must not start with a hyphen"
    return 1
  fi
  if [[ "$name" == "." || "$name" == ".." ]]; then
    err "node name '$name' is not allowed"
    return 1
  fi
  return 0
}
migrate_legacy() {
    # old structure: ~/.flowterm/nodes/ and ~/.flowterm/connections
    # new structure: ~/.flowterm/project1/nodes/ and ~/.flowterm/project1/connections
    # migrate if old structure exists and new structure is not yet set up
    local has_old=0
    [[ -d "$DATA/nodes" ]] && has_old=1
    [[ -f "$DATA/connections" ]] && has_old=1
    [[ $has_old -eq 0 ]] && return
    # only migrate if project1 hasn't already been set up in the new layout
    [[ -d "$DATA/project1/nodes" ]] && return
    mkdir -p "$DATA/project1"
    [[ -d "$DATA/nodes" ]] && mv "$DATA/nodes" "$DATA/project1/nodes"
    [[ -f "$DATA/connections" ]] && mv "$DATA/connections" "$DATA/project1/connections"
    touch "$DATA/project1/connections"
}
migrate_legacy

# ── initial project ──
use_proj "project1"

