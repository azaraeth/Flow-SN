ok()   { echo -e "  ${GR}✓${RS}  ${WH}$*${RS}"; }
err()  { echo -e "  ${RE}✗${RS}  ${RE}$*${RS}"; }
info() { echo -e "  ${GL}·${RS}  ${WD}$*${RS}"; }
warn() { echo -e "  ${OD}!${RS}  ${OD}$*${RS}"; }

hdr()  {
  echo ""
  echo -e "  ${OR}${BD}── $* ${RS}${GY}────────────────────────────────${RS}"
}

div()  { echo -e "  ${GY}${DM}────────────────────────────────────────${RS}"; }

