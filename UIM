# ── Colors ─────────────────────────────────────
OR='\033[38;5;208m'   # orange
OD='\033[38;5;166m'   # orange dim
GR='\033[38;5;114m'   # green
RE='\033[38;5;203m'   # red
BL='\033[38;5;111m'   # blue
GL='\033[38;5;245m'   # grey light
GY='\033[38;5;240m'   # grey
WH='\033[38;5;255m'   # white
WD='\033[38;5;250m'   # white dim
CY='\033[38;5;87m'    # cyan — decision nodes
BD='\033[1m'
DM='\033[2m'
RS='\033[0m'

# ── Storage ─────────────────────────────────────
DATA="$HOME/.flowterm"
PROJ="project1"

use_proj() {
    PROJ="$1"
    NODES="$DATA/$PROJ/nodes"
    CONNS="$DATA/$PROJ/connections"
    mkdir -p "$NODES"
    touch "$CONNS"
}

# ── migrate legacy flat structure on first run ──
migrate_legacy() {
    [[ -d "$DATA/nodes" && ! -d "$DATA/project1" ]] || return
    mkdir -p "$DATA/project1"
    mv "$DATA/nodes" "$DATA/project1/nodes"
    [[ -f "$DATA/connections" ]] && mv "$DATA/connections" "$DATA/project1/connections"
    touch "$DATA/project1/connections"
}
migrate_legacy

# ── initial project ──
use_proj "project1"

